{
  "manifest_version": 3,
  "name": "WebRobot Pipeline Designer",
  "version": "0.1.0",
  "description": "Pick selectors on any page and design + run WebRobot ETL pipelines.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>", "https://api.webrobot.eu/*"],
  "background": { "service_worker": "src/background/service-worker.js" },
  "side_panel": { "default_path": "sidepanel/index.html" },
  "action": { "default_title": "WebRobot Pipeline Designer" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
