{
  "manifest_version": 3,
  "name": "WebRobot Pipeline Designer",
  "version": "0.1.0",
  "description": "Pick selectors on any page and design + run WebRobot ETL pipelines.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>", "https://api.webrobot.eu/*"],
  "background": { "scripts": ["src/background/service-worker.js"] },
  "sidebar_action": {
    "default_panel": "sidepanel/index.html",
    "default_title": "WebRobot Pipeline Designer"
  },
  "action": { "default_title": "WebRobot Pipeline Designer" },
  "browser_specific_settings": {
    "gecko": { "id": "pipeline-designer@webrobot.eu", "strict_min_version": "115.0" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
